---
import Base from '../../../layouts/Base.astro';
import StepConfirm from '../../../components/booking/StepConfirm.astro';
import StepDateTime from '../../../components/booking/StepDateTime.astro';
import StepService from '../../../components/booking/StepService.astro';
import { demoData, demoWeek } from '../../../data/demo';

const bookingDemoData = {
  demoWeek,
  ...demoData,
};
---

<Base
  title="Démo réservation - Infinite Thinking"
  description="Démo mobile du parcours de réservation client Infinite Thinking."
>
  <main class="booking-page">
    <section class="booking-app" aria-label="Démo de réservation">
      <header class="booking-header">
        <p>Démo client</p>
        <h1>Réserver un rendez-vous</h1>

        <ol class="progress-indicator" aria-label="Progression de la réservation">
          <li class="is-active" data-progress-step="1">
            <span>1</span>
            Prestation
          </li>
          <li data-progress-step="2">
            <span>2</span>
            Horaire
          </li>
          <li data-progress-step="3">
            <span>3</span>
            Confirmation
          </li>
        </ol>
      </header>

      <StepService />
      <StepDateTime />
      <StepConfirm />
    </section>
  </main>

  <script id="booking-demo-data" type="application/json" set:html={JSON.stringify(bookingDemoData)}></script>

  <script>
    import { generateIcs } from '../../../utils/generateIcs';

    const dataElement = document.getElementById('booking-demo-data');
    const demo = dataElement ? JSON.parse(dataElement.textContent || '{}') : {};

    const queryPractice = new URLSearchParams(window.location.search).get('practice');
    const genericServiceNames = [
      'Prestation express',
      'Prestation standard',
      'Prestation approfondie',
      'Prestation signature',
      'Suivi personnalisé',
      'Bilan complet',
    ];

    const state = {
      step: 1,
      pickerStage: 'practitioner',
      practiceId: resolvePracticeId(),
      serviceId: '',
      staffId: 'any',
      selectedYear: '',
      selectedMonth: '',
      selectedDate: '',
      slot: null,
      reference: '',
      notificationPreference: 'sms',
    };

    const dayLabels = ['dim.', 'lun.', 'mar.', 'mer.', 'jeu.', 'ven.', 'sam.'];
    const monthLabels = ['janv.', 'févr.', 'mars', 'avr.', 'mai', 'juin', 'juil.', 'août', 'sept.', 'oct.', 'nov.', 'déc.'];
    const longMonthLabels = ['janvier', 'février', 'mars', 'avril', 'mai', 'juin', 'juillet', 'août', 'septembre', 'octobre', 'novembre', 'décembre'];

    const $ = selector => document.querySelector(selector);
    const $$ = selector => Array.from(document.querySelectorAll(selector));

    function resolvePracticeId() {
      if (!queryPractice) return demo.practices?.[0]?.id || '';

      const normalized = queryPractice.toLowerCase();
      const matchedPractice = demo.practices.find(practice => {
        const haystack = `${practice.id} ${practice.name} ${practice.city}`.toLowerCase();
        return haystack.includes(normalized);
      });

      return matchedPractice?.id || demo.practices?.[0]?.id || '';
    }

    const getPractice = id => demo.practices.find(practice => practice.id === id);
    const getService = id => demo.services.find(service => service.id === id);
    const getStaff = id => demo.staff.find(member => member.id === id);
    const getStaffForService = serviceId => {
      const staffIds = demo.staff_services
        .filter(link => link.service_id === serviceId)
        .map(link => link.staff_id);

      return demo.staff.filter(member => staffIds.includes(member.id) && member.active);
    };
    const formatPrice = amount => `CHF ${Number(amount).toLocaleString('fr-CH')}`;
    const dayKeys = ['sun', 'mon', 'tue', 'wed', 'thu', 'fri', 'sat'];
    const getDatePart = timestamp => timestamp.slice(0, 10);
    const getTimePart = timestamp => timestamp.slice(11, 16);
    const getYearPart = timestamp => timestamp.slice(0, 4);
    const getMonthPart = timestamp => timestamp.slice(5, 7);
    const escapeHtml = value =>
      String(value)
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');
    const unique = values => [...new Set(values)].filter(Boolean);

    function formatDate(date) {
      const midday = new Date(`${date}T12:00:00`);
      return `${dayLabels[midday.getDay()]} ${midday.getDate()} ${monthLabels[midday.getMonth()]}`;
    }

    function timeToMinutes(time) {
      const [hours, minutes] = time.split(':').map(Number);
      return hours * 60 + minutes;
    }

    function minutesToTime(minutes) {
      return `${String(Math.floor(minutes / 60)).padStart(2, '0')}:${String(minutes % 60).padStart(2, '0')}`;
    }

    function makeTimestamp(date, minutes) {
      return `${date}T${minutesToTime(minutes)}:00+02:00`;
    }

    function addDays(dateString, days) {
      const date = new Date(`${dateString}T12:00:00`);
      date.setDate(date.getDate() + days);
      return date.toISOString().slice(0, 10);
    }

    function getWeekdayDates() {
      const dates = [];
      let current = demo.demoWeek.start_date;

      while (current <= demo.demoWeek.end_date) {
        const day = new Date(`${current}T12:00:00`).getDay();
        if (day >= 1 && day <= 5) dates.push(current);
        current = addDays(current, 1);
      }

      return dates;
    }

    function overlaps(startA, endA, startB, endB) {
      return startA < endB && endA > startB;
    }

    function getDisplayServiceName(serviceId) {
      const practice = getPractice(state.practiceId);
      const practiceServices = demo.services.filter(service => service.practice_id === practice?.id && service.active);
      const index = Math.max(practiceServices.findIndex(service => service.id === serviceId), 0);
      return genericServiceNames[index] || `Prestation ${index + 1}`;
    }

    function resetDateSelection() {
      state.selectedYear = '';
      state.selectedMonth = '';
      state.selectedDate = '';
      state.slot = null;
    }

    function setStep(step) {
      state.step = step;

      $$('[data-step-panel]').forEach(panel => {
        const isActive = panel.dataset.stepPanel === String(step);
        panel.hidden = !isActive;
        panel.classList.toggle('is-active', isActive);
      });

      $$('[data-progress-step]').forEach(item => {
        const itemStep = Number(item.dataset.progressStep);
        item.classList.toggle('is-active', itemStep === step);
        item.classList.toggle('is-complete', itemStep < step);
      });
    }

    function renderServiceStep() {
      const practice = getPractice(state.practiceId);
      const intro = $('[data-practice-intro]');
      const brandNote = $('[data-brand-note]');
      const serviceList = $('[data-service-list]');
      if (!practice || !intro || !brandNote || !serviceList) return;

      intro.textContent = `${practice.name} · ${practice.address}, ${practice.city}`;
      brandNote.textContent = 'Dans une vraie installation, cette page reprend vos couleurs, votre logo, vos textes et vos photos.';

      const services = demo.services.filter(service => service.practice_id === practice.id && service.active);
      serviceList.innerHTML = services
        .map((service, index) => {
          const name = genericServiceNames[index] || `Prestation ${index + 1}`;
          return `
            <article class="service-card">
              <div>
                <h3>${escapeHtml(name)}</h3>
                <p>${service.duration_minutes} min · ${formatPrice(service.base_price)}</p>
                <small>${service.payment_timing === 'upfront' ? 'Paiement à la réservation' : 'Paiement après le rendez-vous'}</small>
              </div>
              <button type="button" data-service-id="${service.id}">Choisir</button>
            </article>
          `;
        })
        .join('');

      serviceList.querySelectorAll('button').forEach(button => {
        button.addEventListener('click', () => {
          state.serviceId = button.dataset.serviceId || '';
          state.staffId = 'any';
          state.pickerStage = 'practitioner';
          resetDateSelection();
          renderDateTimeStep();
          setStep(2);
        });
      });
    }

    function getBaseSlots() {
      const service = getService(state.serviceId);
      if (!service) return [];

      const eligibleStaff = getStaffForService(state.serviceId)
        .filter(member => state.staffId === 'any' || member.id === state.staffId);

      return eligibleStaff.flatMap(member => {
        const buffer = member.buffer_override_minutes ?? getPractice(state.practiceId)?.default_buffer_minutes ?? 15;
        const bookings = demo.bookings.filter(booking => booking.staff_id === member.id);

        return getWeekdayDates().flatMap(date => {
          const dayKey = dayKeys[new Date(`${date}T12:00:00`).getDay()];
          const workingDay = member.working_hours?.[dayKey];
          if (!workingDay) return [];

          const dayStart = timeToMinutes(workingDay.start);
          const dayEnd = timeToMinutes(workingDay.end);
          const breakStart = workingDay.break ? timeToMinutes(workingDay.break.start) : null;
          const breakEnd = workingDay.break ? timeToMinutes(workingDay.break.end) : null;
          const slots = [];

          for (let start = dayStart; start + service.duration_minutes <= dayEnd; start += 30) {
            const end = start + service.duration_minutes;
            const crossesBreak =
              breakStart !== null && breakEnd !== null && overlaps(start, end, breakStart, breakEnd);
            const crossesBooking = bookings.some(booking => {
              if (getDatePart(booking.start_time) !== date) return false;
              return overlaps(start, end, timeToMinutes(getTimePart(booking.start_time)), timeToMinutes(getTimePart(booking.end_time)));
            });

            if (crossesBreak || crossesBooking) continue;

            slots.push({
              practice_id: state.practiceId,
              staff_id: member.id,
              service_id: service.id,
              start_time: makeTimestamp(date, start),
              end_time: makeTimestamp(date, end),
              status: 'disponible',
              booking_id: null,
            });
          }

          return slots;
        });
      }).sort((a, b) => a.start_time.localeCompare(b.start_time));
    }

    function renderTrail() {
      const trail = $('[data-selection-trail]');
      if (!trail) return;

      const staffMember = state.staffId === 'any' ? null : getStaff(state.staffId);
      const parts = [getDisplayServiceName(state.serviceId)];
      if (state.staffId) parts.push(staffMember ? `${staffMember.first_name} ${staffMember.last_name}` : 'Sans préférence');
      if (state.selectedYear) parts.push(state.selectedYear);
      if (state.selectedMonth) parts.push(longMonthLabels[Number(state.selectedMonth) - 1]);
      if (state.selectedDate) parts.push(formatDate(state.selectedDate));

      trail.innerHTML = parts.map(part => `<span>${escapeHtml(part)}</span>`).join('');
    }

    function renderChoiceButtons(items) {
      return `<div class="choice-grid">${items.map(item => `
        <button class="choice-button" type="button" data-choice="${escapeHtml(item.value)}" ${item.disabled ? 'disabled' : ''}>
          <strong>${escapeHtml(item.label)}</strong>
          ${item.meta ? `<span>${escapeHtml(item.meta)}</span>` : ''}
        </button>
      `).join('')}</div>`;
    }

    function renderDateTimeStep() {
      const selectedServiceCopy = $('[data-selected-service-copy]');
      const title = $('[data-picker-title]');
      const picker = $('[data-booking-picker]');
      const service = getService(state.serviceId);
      if (!selectedServiceCopy || !title || !picker || !service) return;

      selectedServiceCopy.textContent = `${getDisplayServiceName(service.id)} · ${service.duration_minutes} min · ${formatPrice(service.base_price)}`;
      renderTrail();

      if (state.pickerStage === 'practitioner') renderPractitionerPicker(title, picker);
      if (state.pickerStage === 'year') renderYearPicker(title, picker);
      if (state.pickerStage === 'month') renderMonthPicker(title, picker);
      if (state.pickerStage === 'day') renderDayPicker(title, picker);
      if (state.pickerStage === 'slot') renderSlotPicker(title, picker);
    }

    function renderPractitionerPicker(title, picker) {
      title.textContent = 'Choisissez un praticien';
      const eligibleStaff = getStaffForService(state.serviceId);
      picker.innerHTML = renderChoiceButtons([
        { value: 'any', label: 'Sans préférence', meta: 'Le premier créneau disponible' },
        ...eligibleStaff.map(member => ({
          value: member.id,
          label: `${member.first_name} ${member.last_name}`,
          meta: 'Disponible selon son agenda',
        })),
      ]);

      picker.querySelectorAll('[data-choice]').forEach(button => {
        button.addEventListener('click', () => {
          state.staffId = button.dataset.choice;
          state.pickerStage = 'year';
          resetDateSelection();
          renderDateTimeStep();
        });
      });
    }

    function renderYearPicker(title, picker) {
      title.textContent = 'Choisissez une année';
      const years = unique(getBaseSlots().map(slot => getYearPart(slot.start_time)));
      picker.innerHTML = renderChoiceButtons(years.map(year => ({ value: year, label: year, meta: 'Créneaux disponibles' })));
      picker.querySelectorAll('[data-choice]').forEach(button => {
        button.addEventListener('click', () => {
          state.selectedYear = button.dataset.choice;
          state.selectedMonth = '';
          state.selectedDate = '';
          state.pickerStage = 'month';
          renderDateTimeStep();
        });
      });
    }

    function renderMonthPicker(title, picker) {
      title.textContent = 'Choisissez un mois';
      const months = unique(
        getBaseSlots()
          .filter(slot => getYearPart(slot.start_time) === state.selectedYear)
          .map(slot => getMonthPart(slot.start_time))
      );
      picker.innerHTML = renderChoiceButtons(months.map(month => ({
        value: month,
        label: longMonthLabels[Number(month) - 1],
        meta: state.selectedYear,
      })));
      picker.querySelectorAll('[data-choice]').forEach(button => {
        button.addEventListener('click', () => {
          state.selectedMonth = button.dataset.choice;
          state.selectedDate = '';
          state.pickerStage = 'day';
          renderDateTimeStep();
        });
      });
    }

    function renderDayPicker(title, picker) {
      title.textContent = 'Choisissez un jour';
      const days = unique(
        getBaseSlots()
          .filter(slot => getYearPart(slot.start_time) === state.selectedYear)
          .filter(slot => getMonthPart(slot.start_time) === state.selectedMonth)
          .map(slot => getDatePart(slot.start_time))
      );
      picker.innerHTML = renderChoiceButtons(days.map(date => {
        const availableCount = getBaseSlots().filter(slot => getDatePart(slot.start_time) === date && slot.status === 'disponible').length;
        return { value: date, label: formatDate(date), meta: `${availableCount} créneau(x)` };
      }));
      picker.querySelectorAll('[data-choice]').forEach(button => {
        button.addEventListener('click', () => {
          state.selectedDate = button.dataset.choice;
          state.pickerStage = 'slot';
          renderDateTimeStep();
        });
      });
    }

    function renderSlotPicker(title, picker) {
      title.textContent = 'Choisissez un créneau';
      const slots = getBaseSlots().filter(slot => getDatePart(slot.start_time) === state.selectedDate);
      picker.innerHTML = `
        <div class="slot-list slot-list-large">
          ${slots.length ? slots.map(slot => {
            const member = getStaff(slot.staff_id);
            const isBooked = slot.status === 'réservé';
            return `
              <button
                class="slot-button ${isBooked ? 'is-booked' : ''}"
                type="button"
                data-slot-start="${slot.start_time}"
                data-slot-staff="${slot.staff_id}"
                ${isBooked ? 'disabled' : ''}
              >
                <span>${getTimePart(slot.start_time)}</span>
                <small>${member ? `${escapeHtml(member.first_name)} ${escapeHtml(member.last_name)}` : 'Praticien'}</small>
              </button>
            `;
          }).join('') : '<p class="empty-day">Aucun créneau pour ce jour.</p>'}
        </div>
      `;

      picker.querySelectorAll('.slot-button:not(.is-booked)').forEach(button => {
        button.addEventListener('click', () => {
          state.slot = slots.find(slot => slot.start_time === button.dataset.slotStart && slot.staff_id === button.dataset.slotStaff) || null;
          if (state.slot && state.staffId === 'any') state.staffId = state.slot.staff_id;
          $('[data-confirm-form]').hidden = false;
          $('[data-confirmation-screen]').hidden = true;
          $('[data-back-to-datetime]').hidden = false;
          renderConfirmStep();
          setStep(3);
        });
      });
    }

    function renderSummary(targetSelector, includeReference = false) {
      const target = $(targetSelector);
      const practice = getPractice(state.practiceId);
      const service = getService(state.serviceId);
      const staffMember = getStaff(state.slot?.staff_id || state.staffId);
      if (!target || !practice || !service || !staffMember || !state.slot) return;

      target.innerHTML = `
        ${includeReference ? `<p class="reference">Référence ${escapeHtml(state.reference)}</p>` : ''}
        <dl>
          <div>
            <dt>Prestation</dt>
            <dd>${escapeHtml(getDisplayServiceName(service.id))}</dd>
          </div>
          <div>
            <dt>Praticien</dt>
            <dd>${escapeHtml(staffMember.first_name)} ${escapeHtml(staffMember.last_name)}</dd>
          </div>
          <div>
            <dt>Date</dt>
            <dd>${formatDate(getDatePart(state.slot.start_time))} à ${getTimePart(state.slot.start_time)}</dd>
          </div>
          <div>
            <dt>Lieu</dt>
            <dd>${escapeHtml(practice.address)}, ${escapeHtml(practice.city)}</dd>
          </div>
          <div>
            <dt>Prix</dt>
            <dd>${formatPrice(service.base_price)}</dd>
          </div>
        </dl>
      `;
    }

    function renderConfirmStep() {
      renderSummary('[data-summary]');
    }

    function makeReference() {
      const value = Math.floor(100000 + Math.random() * 900000);
      return `RDV-${value}`;
    }

    function downloadIcs() {
      const practice = getPractice(state.practiceId);
      const service = getService(state.serviceId);
      const staffMember = getStaff(state.slot?.staff_id || state.staffId);
      if (!practice || !service || !staffMember || !state.slot) return;

      const reference = state.reference || makeReference();
      state.reference = reference;
      const content = generateIcs({
        id: reference,
        serviceName: getDisplayServiceName(service.id),
        practitionerName: `${staffMember.first_name} ${staffMember.last_name}`,
        practiceAddress: practice.address,
        practiceCity: practice.city,
        startTime: new Date(state.slot.start_time),
        endTime: new Date(state.slot.end_time),
        cancelUrl: new URL('#annulation-demo', window.location.href).toString(),
      });

      const blob = new Blob([content], { type: 'text/calendar;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.href = url;
      link.download = `rdv-${getDatePart(state.slot.start_time)}.ics`;
      document.body.appendChild(link);
      link.click();
      link.remove();
      URL.revokeObjectURL(url);
    }

    $('[data-back-to-services]')?.addEventListener('click', () => {
      state.pickerStage = 'practitioner';
      state.staffId = 'any';
      resetDateSelection();
      setStep(1);
    });

    $('[data-back-to-datetime]')?.addEventListener('click', () => {
      renderDateTimeStep();
      setStep(2);
    });

    $$('[data-notification-preference]').forEach(input => {
      input.addEventListener('change', event => {
        state.notificationPreference = event.target.value;
      });
    });

    $('[data-confirm-booking]')?.addEventListener('click', () => {
      state.reference = makeReference();
      $('[data-confirm-form]').hidden = true;
      $('[data-confirmation-screen]').hidden = false;
      $('[data-back-to-datetime]').hidden = true;
      renderSummary('[data-confirmation-summary]', true);
    });

    $('[data-download-ics]')?.addEventListener('click', downloadIcs);
    $('[data-cancel-demo]')?.addEventListener('click', event => event.preventDefault());

    renderServiceStep();
    setStep(1);
  </script>

  <style is:global>
    .booking-page {
      min-height: 100vh;
      padding: 28px 16px 48px;
      background:
        radial-gradient(circle at top, rgba(200, 169, 110, 0.18), transparent 22rem),
        var(--paper);
    }

    .booking-app {
      width: min(100%, 420px);
      margin: 0 auto;
      border: 1px solid var(--line);
      background: rgba(245, 242, 236, 0.94);
      box-shadow: 0 24px 80px rgba(13, 13, 11, 0.08);
    }

    .booking-header {
      padding: 28px 22px 22px;
      border-bottom: 1px solid var(--line);
    }

    .booking-header > p,
    .booking-eyebrow {
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent-dark);
    }

    .booking-header h1,
    .booking-step h2 {
      margin-top: 10px;
      font-size: clamp(34px, 10vw, 46px);
      font-weight: 300;
      line-height: 1.05;
    }

    .progress-indicator {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin-top: 24px;
      list-style: none;
    }

    .progress-indicator li {
      display: grid;
      gap: 8px;
      color: var(--muted);
      font-family: 'DM Mono', monospace;
      font-size: 9px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .progress-indicator span {
      display: grid;
      place-items: center;
      width: 30px;
      height: 30px;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: var(--paper);
      color: var(--muted);
    }

    .progress-indicator .is-active,
    .progress-indicator .is-complete {
      color: var(--ink);
    }

    .progress-indicator .is-active span,
    .progress-indicator .is-complete span {
      border-color: var(--accent-dark);
      background: var(--ink);
      color: var(--paper);
    }

    .booking-step {
      padding: 26px 22px 28px;
    }

    .booking-step[hidden],
    [hidden] {
      display: none !important;
    }

    .booking-muted {
      margin-top: 12px;
      color: var(--muted);
      font-size: 16px;
      line-height: 1.55;
    }

    .brand-note {
      margin-top: 14px;
      border-left: 3px solid var(--accent);
      background: rgba(200, 169, 110, 0.12);
      color: var(--accent-dark);
      font-size: 15px;
      line-height: 1.45;
      padding: 12px 14px;
    }

    .selection-trail {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 18px;
    }

    .selection-trail span {
      border: 1px solid var(--line);
      color: var(--muted);
      font-family: 'DM Mono', monospace;
      font-size: 9px;
      letter-spacing: 0.12em;
      padding: 6px 9px;
      text-transform: uppercase;
    }

    .booking-picker {
      margin-top: 20px;
    }

    .choice-grid {
      display: grid;
      gap: 10px;
    }

    .choice-button {
      display: grid;
      gap: 5px;
      width: 100%;
      border: 1px solid var(--line);
      background: rgba(255, 255, 255, 0.28);
      color: var(--ink);
      cursor: pointer;
      padding: 16px;
      text-align: left;
    }

    .choice-button strong {
      font-size: 22px;
      font-weight: 300;
      line-height: 1.1;
    }

    .choice-button span {
      color: var(--muted);
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .choice-button:hover {
      border-color: var(--accent-dark);
      background: var(--paper-warm);
    }

    .practice-switcher {
      display: grid;
      grid-template-columns: 1fr;
      gap: 8px;
      margin: 20px 0;
    }

    .practice-switcher button,
    .back-button {
      border: 1px solid var(--line);
      background: transparent;
      color: var(--muted);
      cursor: pointer;
    }

    .practice-switcher button {
      padding: 12px 14px;
      text-align: left;
      font-family: 'DM Mono', monospace;
      font-size: 10px;
